<script>
  // ─── NAVIGATION ───
  function goToSelect() {
    const fname = document.getElementById('fname').value.trim();
    if (!fname) {
      document.getElementById('fname').focus();
      document.getElementById('fname').style.borderColor = 'var(--gold)';
      return;
    }
    switchScreen('screen-login', 'screen-select');
  }

  function goToMain() {
    switchScreen('screen-select', 'screen-main');
    setTimeout(initScrollReveal, 100);
  }

  function switchScreen(fromId, toId) {
    document.getElementById(fromId).classList.remove('active');
    const to = document.getElementById(toId);
    to.classList.add('active');
    to.style.animation = 'fadeUp 0.5s ease both';
  }

  function scrollTo(selector) {
    const el = document.querySelector(selector);
    if (el) el.scrollIntoView({ behavior: 'smooth' });
  }

  // ─── CONVERTER ───
  let direction = 'cfa'; // 'cfa' or 'dzd'
  const RATE_CFA_TO_DZD = 19500 / 50000; // 0.39
  const RATE_DZD_TO_CFA = 50000 / 22000; // ~2.2727

  function setDirection(dir) {
    direction = dir;
    document.getElementById('tab-cfa').classList.toggle('active', dir === 'cfa');
    document.getElementById('tab-dzd').classList.toggle('active', dir === 'dzd');

    if (dir === 'cfa') {
      document.getElementById('from-label').textContent = 'Montant en CFA';
      document.getElementById('from-badge').textContent = 'XOF';
      document.getElementById('to-label').textContent = 'Vous recevez en DZD';
      document.getElementById('result-currency').textContent = 'Dinars Algériens';
      document.getElementById('result-rate').textContent = 'Taux : 50 000 XOF = 19 500 DZD';
    } else {
      document.getElementById('from-label').textContent = 'Montant en DZD';
      document.getElementById('from-badge').textContent = 'DZD';
      document.getElementById('to-label').textContent = 'Vous recevez en CFA';
      document.getElementById('result-currency').textContent = 'Francs CFA';
      document.getElementById('result-rate').textContent = 'Taux : 22 000 DZD = 50 000 XOF';
    }
    document.getElementById('amount-input').value = '';
    document.getElementById('result-value').textContent = '0';
  }

  function convertAmount() {
    const amt = parseFloat(document.getElementById('amount-input').value) || 0;
    let result = 0;
    if (direction === 'cfa') {
      result = amt * RATE_CFA_TO_DZD;
    } else {
      result = amt * RATE_DZD_TO_CFA;
    }
    const el = document.getElementById('result-value');
    el.style.transform = 'scale(1.05)';
    el.style.color = 'var(--gold-light)';
    setTimeout(() => { el.style.transform = 'scale(1)'; }, 200);
    el.textContent = Math.round(result).toLocaleString('fr-FR');
  }

  // ─── SCROLL REVEAL ───
  function initScrollReveal() {
    const els = document.querySelectorAll('.scroll-reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    els.forEach(el => observer.observe(el));
  }
</script>
